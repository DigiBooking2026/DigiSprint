generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int
  type      String
  createdAt DateTime @default(now())
  projectId String?
  taskId    String?
  commentId String?
  project   Project? @relation(fields: [projectId], references: [id], map: "Attachment_projectId_fkey")
  task      Task?    @relation(fields: [taskId], references: [id], map: "Attachment_taskId_fkey")
  comment   Comment? @relation(fields: [commentId], references: [id], map: "Attachment_commentId_fkey")

  @@index([projectId], map: "Attachment_projectId_fkey")
  @@index([taskId], map: "Attachment_taskId_fkey")
  @@index([commentId], map: "Attachment_commentId_fkey")
  @@map("attachment")
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?      @db.LongText
  prefix      String       @default("DB")
  startDate   DateTime?
  deadline    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attachments Attachment[]
  tasks       Task[]
  statuses    TaskStatus[]
  sprints     Sprint[]
  ownerId     String?
  owner       User?        @relation("project_owner", fields: [ownerId], references: [id])
  isPrivate   Boolean      @default(false)
  members     User[]       @relation("project_members")
  releases    Release[]
  
  @@map("project")
}

model Sprint {
  id          String       @id @default(cuid())
  name        String
  goal        String?      @db.LongText
  startDate   DateTime?
  endDate     DateTime?
  status      String       @default("PLANNED") // PLANNED, ACTIVE, COMPLETED
  projectId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([projectId])
  @@map("sprint")
}

model Release {
  id          String       @id @default(cuid())
  name        String
  description String?      @db.LongText
  releaseDate DateTime?
  status      String       @default("UNRELEASED") // UNRELEASED, RELEASED, ARCHIVED
  projectId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([projectId])
  @@map("release")
}

model Task {
  id          String        @id @default(cuid())
  ticketId    String        @unique(map: "Task_ticketId_key")
  title       String
  description String?       @db.LongText
  type        String        @default("TASK")
  category    String?
  priority    String        @default("MEDIUM")
  blockedReason String?     @db.LongText
  storyPoints Float         @default(0)
  loggedTime  Float         @default(0)
  startDate   DateTime?
  deadline    DateTime?
  statusId    String
  projectId   String
  sprintId    String?
  releaseId   String?
  ownerId     String
  assigneeId  String?
  parentId    String?
  epicId      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  attachments Attachment[]
  assignee    User?         @relation("task_assignee", fields: [assigneeId], references: [id], map: "Task_assigneeId_fkey")
  owner       User          @relation("task_owner", fields: [ownerId], references: [id], map: "Task_ownerId_fkey")
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "Task_projectId_fkey")
  sprint      Sprint?       @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  release     Release?      @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  status      TaskStatus    @relation(fields: [statusId], references: [id], map: "Task_statusId_fkey")
  history     TaskHistory[]
  comments    Comment[]
  worklogs    Worklog[]
  tags        Tag[]
  
  parent      Task?         @relation("TaskToSubtasks", fields: [parentId], references: [id], onDelete: Cascade, map: "Task_parentId_fkey")
  subtasks    Task[]        @relation("TaskToSubtasks")
  epic        Task?         @relation("EpicTasks", fields: [epicId], references: [id], onDelete: SetNull)
  epicTasks   Task[]        @relation("EpicTasks")
  sourceLinks TaskLink[]    @relation("TaskLinkSource")
  targetLinks TaskLink[]    @relation("TaskLinkTarget")

  @@index([assigneeId], map: "Task_assigneeId_fkey")
  @@index([ownerId], map: "Task_ownerId_fkey")
  @@index([projectId], map: "Task_projectId_fkey")
  @@index([sprintId])
  @@index([releaseId])
  @@index([statusId], map: "Task_statusId_fkey")
  @@index([parentId], map: "Task_parentId_fkey")
  @@index([epicId])
  @@map("task")
}

model TaskLink {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  type      String   // e.g., "BLOCKS", "IS_BLOCKED_BY", "RELATES_TO", "DUPLICATES"
  createdAt DateTime @default(now())

  source    Task     @relation("TaskLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target    Task     @relation("TaskLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@index([sourceId])
  @@index([targetId])
  @@map("tasklink")
}

model Comment {
  id          String       @id @default(cuid())
  content     String       @db.LongText
  taskId      String
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  attachments Attachment[]

  @@index([taskId])
  @@index([userId])
  @@map("comment")
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  oldStatus String?
  newStatus String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, map: "TaskHistory_taskId_fkey")
  user      User     @relation(fields: [userId], references: [id], map: "TaskHistory_userId_fkey")

  @@index([taskId], map: "TaskHistory_taskId_fkey")
  @@index([userId], map: "TaskHistory_userId_fkey")
  @@map("taskhistory")
}

model TaskStatus {
  id        String   @id @default(cuid())
  name      String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  tasks     Task[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "TaskStatus_projectId_fkey")

  @@unique([name, projectId], map: "TaskStatus_name_projectId_key")
  @@index([projectId], map: "TaskStatus_projectId_fkey")
  @@map("taskstatus")
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
  tasks     Task[]

  @@map("tag")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique(map: "User_email_key")
  name          String?
  password      String
  role          String        @default("USER")
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  assignedTasks Task[]        @relation("task_assignee")
  ownedTasks    Task[]        @relation("task_owner")
  ownedProjects Project[]     @relation("project_owner")
  memberOfProjects Project[]  @relation("project_members")
  histories     TaskHistory[]
  comments      Comment[]
  worklogs      Worklog[]
  notifications Notification[]
  
  @@map("user")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification")
}

model Worklog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  hours     Float
  notes     String?  @db.LongText
  date      DateTime @default(now()) // The date the work was performed
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@map("worklog")
}
